{
    "name": "scientia-international/conference-discount-eligibility",
    "description": "Automatic eligibility discounts and secure payment-page coupon redemption for Leconfe 1.4.6.",
    "type": "leconfe-plugin",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "ConferenceDiscountEligibility\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ConferenceDiscountEligibility\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:standalone": "php tests/run.php",
        "lint": "php scripts/lint.php",
        "validate:package": "php scripts/validate-package.php",
        "security:scan": "php scripts/secret-scan.php"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": false
    }
}
